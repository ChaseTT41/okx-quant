# Chase量化策略 — 环境变量配置模板
# ====================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
#
# ⚠️ 不要将 .env 提交到 Git！

# ── 必填 ──
# 企业微信 Webhook Key (日报推送)
WECHAT_WEBHOOK_KEY=

# ── 安全配置 (公网部署必设) ──
# 生产模式: 启用速率限制、禁用 /docs、严格安全头
PRODUCTION=true

# 管理员密钥: 设置后，策略编辑/删除/启停、手动交易/平仓都需要此令牌
# 留空 = 所有人可操作 (不安全！仅本地开发使用)
ADMIN_TOKEN=your-secret-admin-key-here

# 速率限制: 每 IP 每分钟最大请求数
RATE_LIMIT_PER_MIN=120
# 写操作 (POST/PUT/DELETE) 每 IP 每分钟限制
RATE_LIMIT_MUTATION_PER_MIN=10

# IP 白名单 (逗号分隔, 白名单IP不受限)
# IP_WHITELIST=192.168.1.1,10.0.0.1

# IP 黑名单 (逗号分隔, 永久封锁)
# IP_BLACKLIST=1.2.3.4

# ── 实盘交易配置 (Phase 15) ──
# 交易所选择: binance | okx
# EXCHANGE=okx
# 交易模式: paper=模拟盘 | testnet=交易所Demo/测试网 | live=实盘
# TRADING_MODE=paper

# ── OKX API 凭证 (推荐) ──
# 在 OKX 官网 → 用户中心 → API → 创建 API Key
# ✅ 开启「交易」权限  ❌ 禁止「提现」权限!
# Passphrase 是创建 API Key 时自己设置的密码短语 (非登录密码!)
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# ── Binance API 凭证 (备选) ──
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=

# ── 实盘风控参数 ──
# LIVE_MIN_BALANCE_USDT=50
# LIVE_MAX_DAILY_TRADES=5
# LIVE_MAX_DRAWDOWN=0.10

# 服务端口
# PORT=8766
